                                               },
                                               {
                                                   "stepIndex":  2,
                                                   "title":  "Visa / Entry Stamp at Immigration Counter",
                                                   "description":  "Join the foreigners queue. Most nationalities receive a 30â€“60 day visa exemption (policy expanded in 2024). Present passport and proof of onward travel. Officers may ask for proof of sufficient funds (THB 10,000 per person / THB 20,000 per family)."
                                               },
                                               {
                                                   "stepIndex":  3,
                                                   "title":  "Biometric Collection",
                                                   "description":  "Fingerprints of both index fingers are scanned at the immigration counter for all foreign nationals. A facial photograph may also be taken."
                                               },
                                               {
                                                   "stepIndex":  4,
                                                   "title":  "Baggage Claim",
                                                   "description":  "Collect luggage from the assigned carousel. Keep your baggage tag stubs for inspection at the exit."
                                               },
                                               {
                                                   "stepIndex":  5,
                                                   "title":  "Customs Declaration",
                                                   "description":  "Pass through the Red Channel if carrying goods over THB 20,000, more than 200 cigarettes, 1L of alcohol, or cash exceeding THB 450,000. Use the Green Channel if you have nothing to declare. Drugs carry the death penalty."
                                               }
