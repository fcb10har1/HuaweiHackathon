                          "arrivalSteps":  [
                                               {
                                                   "stepIndex":  0,
                                                   "title":  "Visa / Visa on Arrival (VOA) Preparation",
                                                   "description":  "Citizens of 97+ countries are eligible for the e-VOA paid online at molina.imigrasi.go.id before travel, or at the on-arrival counter at major airports. Cost: IDR 500,000 (approx. USD 35) for a 30-day stay, extendable once. Pre-purchase online to avoid airport queues. Some nationalities receive free visa-free access for 30 days."
                                               },
                                               {
                                                   "stepIndex":  1,
                                                   "title":  "Health \u0026 Customs e-Declaration",
                                                   "description":  "Complete the Electronic Customs Declaration (CD) via the All Indonesia platform at allindonesia.imigrasi.go.id"
                                               },
                                               {
                                                   "stepIndex":  2,
                                                   "title":  "Passport Control / Immigration Counter",
                                                   "description":  "Present your passport and VOA payment receipt (or visa) at the immigration counter. Officers will verify your documents, take a facial photograph, and stamp your passport. Confirm your intended address and duration of stay."
                                               },
                                               {
                                                   "stepIndex":  3,
                                                   "title":  "Biometrics",
                                                   "description":  "Fingerprint scans (both index fingers) and a facial photograph are taken at the immigration counter for all foreign nationals. This is mandatory under Indonesian immigration law."
                                               },
                                               {
                                                   "stepIndex":  4,
                                                   "title":  "Baggage Claim",
                                                   "description":  "Collect luggage from the designated carousel. Retain baggage receipts as they are checked at the exit. Random luggage scans are common at Bali and Jakarta airports."
                                               },
                                               {
                                                   "stepIndex":  5,
                                                   "title":  "Customs Declaration",
                                                   "description":  "Duty-free: goods up to USD 500 per person, 200 cigarettes, 25 cigars or 100g tobacco, 1L alcohol. Declare cash over USD 10,000. Strictly prohibited: narcotics (death penalty enforced), pornographic material, and agricultural products without a phytosanitary certificate."
                                               }
                                           ],
