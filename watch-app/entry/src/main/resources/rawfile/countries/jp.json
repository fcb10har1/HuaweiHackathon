                          "arrivalSteps":  [
                                               {
                                                   "stepIndex":  0,
                                                   "title":  "Complete Visit Japan Web / Arrival Card",
                                                   "description":  "Before or on the flight, register on Visit Japan Web (vjw-lp.digital.go.jp) to pre-register your immigration and customs info, or fill out the paper Disembarkation Card for Foreigner provided on board. Provide name, passport number, flight number, intended address in Japan, and purpose of visit."
                                               },
                                               {
                                                   "stepIndex":  1,
                                                   "title":  "Quarantine / Health Screening",
                                                   "description":  "Proceed through the health/quarantine checkpoint after deplaning. COVID-era requirements have been lifted as of 2024. Declare any restricted items (fresh produce, meat) on your customs form."
                                               },
                                               {
                                                   "stepIndex":  2,
                                                   "title":  "Immigration (Passport Control)",
                                                   "description":  "Join the foreigner queue at Immigration Control. Present your passport, disembarkation card (or Visit Japan Web QR code), and any required visa. All visitors aged 16+ must provide fingerprint scans and a facial photograph."
                                               },
                                               {
                                                   "stepIndex":  3,
                                                   "title":  "Baggage Claim",
                                                   "description":  "Collect your checked baggage from the designated carousel. Keep your baggage claim tags as officers may check them against bags before you exit the hall."
                                               },
                                               {
                                                   "stepIndex":  4,
                                                   "title":  "Customs Declaration",
                                                   "description":  "Submit the Customs Declaration form (one per family). Declare cash exceeding JPY 1,000,000, gifts over JPY 200,000 duty-free value, and any restricted goods. The Visit Japan Web QR code can be used for the electronic declaration lane."
                                               },
                                               {
                                                   "stepIndex":  5,
                                                   "title":  "Plant / Animal Quarantine (if applicable)",
                                                   "description":  "If carrying fresh fruit, vegetables, meat, or live animals, present them at the Quarantine counter before the customs exit. Undeclared prohibited agricultural items can result in fines or deportation."
                                               }
                                           ],
